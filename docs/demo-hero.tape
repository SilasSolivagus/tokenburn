# tokenburn — 30-second hero GIF for README
# Record with: vhs docs/demo-hero.tape

Output docs/demo-hero.gif

Set Shell "bash"
Set FontSize 16
Set Width 900
Set Height 600
Set Padding 16
Set Theme "Catppuccin Mocha"
Set TypingSpeed 55ms
Set CursorBlink false

Sleep 500ms

Type "tokenburn"
Sleep 200ms
Enter
Sleep 3000ms

# Let report render
Sleep 2000ms

Type "tokenburn scan --last 7d"
Sleep 200ms
Enter
Sleep 4000ms

# Hold final frame
Sleep 3000ms
